<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_vertical_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_vertical_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#142A44"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text="오늘 남은 일정" />

        <TextView
            android:id="@+id/widget_vertical_voice_button"
            android:layout_width="44dp"
            android:layout_height="24dp"
            android:background="@drawable/widget_voice_chip_background"
            android:gravity="center"
            android:text="입력"
            android:textColor="#1F4168"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_vertical_subtitle"
        style="@style/PlanFlowWidgetMetaText"
        android:layout_marginTop="2dp"
        tools:text="현재 다음: 주간 회의" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_today_item_1"
            android:background="@drawable/widget_today_highlight_background"
            android:padding="7dp"
            style="@style/PlanFlowWidgetListText"
            tools:text="09:00  주간 회의" />

        <TextView
            android:id="@+id/widget_today_item_2"
            style="@style/PlanFlowWidgetListText"
            tools:text="11:00  팀 미팅" />

        <TextView
            android:id="@+id/widget_today_item_3"
            style="@style/PlanFlowWidgetListText"
            tools:text="12:00  점심" />

        <TextView
            android:id="@+id/widget_today_item_4"
            style="@style/PlanFlowWidgetListText" />

        <TextView
            android:id="@+id/widget_today_item_5"
            style="@style/PlanFlowWidgetListText" />

        <TextView
            android:id="@+id/widget_today_item_6"
            style="@style/PlanFlowWidgetListText" />
    </LinearLayout>
</LinearLayout>
