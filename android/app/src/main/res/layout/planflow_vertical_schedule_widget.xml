<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_vertical_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_vertical_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#1F2A24"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="오늘 남은 일정" />

    <TextView
        android:id="@+id/widget_vertical_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#5F6B62"
        android:textSize="12sp"
        tools:text="지금 다음: JW제약 미팅" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_today_item_1"
            style="@style/PlanFlowWidgetListText"
            tools:text="10:00 공임나라 방문" />

        <TextView
            android:id="@+id/widget_today_item_2"
            style="@style/PlanFlowWidgetListText"
            tools:text="14:00 미팅" />

        <TextView
            android:id="@+id/widget_today_item_3"
            style="@style/PlanFlowWidgetListText"
            tools:text="16:00 병원" />

        <TextView
            android:id="@+id/widget_today_item_4"
            style="@style/PlanFlowWidgetListText" />

        <TextView
            android:id="@+id/widget_today_item_5"
            style="@style/PlanFlowWidgetListText" />

        <TextView
            android:id="@+id/widget_today_item_6"
            style="@style/PlanFlowWidgetListText" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_vertical_voice_button"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:background="#5D61A8"
        android:gravity="center"
        android:text="마이크로 일정 관리"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
