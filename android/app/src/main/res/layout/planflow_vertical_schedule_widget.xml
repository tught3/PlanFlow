<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_vertical_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_vertical_title"
            style="@style/PlanFlowWidgetTitleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            tools:text="오늘 일정" />

        <TextView
            android:id="@+id/widget_vertical_voice_button"
            style="@style/PlanFlowWidgetVoiceChip"
            android:layout_width="44dp"
            android:layout_height="24dp"
            android:text="입력" />
    </LinearLayout>

    <TextView
        style="@style/PlanFlowWidgetSectionText"
        android:layout_marginTop="8dp"
        android:text="최근 지난 일정" />

    <TextView
        android:id="@+id/widget_last_past_event_1_title"
        style="@style/PlanFlowWidgetListText"
        tools:text="10:00 회의" />

    <TextView
        android:id="@+id/widget_last_past_event_2_title"
        style="@style/PlanFlowWidgetListText"
        tools:text="14:00 병원" />

    <TextView
        style="@style/PlanFlowWidgetSectionText"
        android:layout_marginTop="10dp"
        android:text="오늘 남은 일정" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_1_title"
        style="@style/PlanFlowWidgetListText"
        tools:text="16:20 회의실 이동" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_2_title"
        style="@style/PlanFlowWidgetListText"
        tools:text="18:00 저녁 식사" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_3_title"
        style="@style/PlanFlowWidgetListText" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_4_title"
        style="@style/PlanFlowWidgetListText" />

    <TextView
        android:id="@+id/widget_today_upcoming_empty_message"
        style="@style/PlanFlowWidgetSubtleText"
        android:visibility="gone"
        android:text="오늘 남은 일정은 없어요" />

    <TextView
        style="@style/PlanFlowWidgetSectionText"
        android:layout_marginTop="10dp"
        android:text="내일 일정" />

    <TextView
        android:id="@+id/widget_tomorrow_event_1_title"
        style="@style/PlanFlowWidgetListText"
        tools:text="09:00 방문 미팅" />

    <TextView
        android:id="@+id/widget_tomorrow_event_2_title"
        style="@style/PlanFlowWidgetListText"
        tools:text="11:30 약속" />
</LinearLayout>
