<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_vertical_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_vertical_prev_button"
                style="@style/PlanFlowWidgetMonthNavButton"
                android:layout_width="32dp"
                android:layout_height="30dp"
                android:text="‹" />

            <TextView
                android:id="@+id/widget_vertical_title"
                style="@style/PlanFlowWidgetTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:gravity="center"
                tools:text="오늘 일정" />

            <TextView
                android:id="@+id/widget_vertical_next_button"
                style="@style/PlanFlowWidgetMonthNavButton"
                android:layout_width="32dp"
                android:layout_height="30dp"
                android:text="›" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_vertical_voice_button"
            style="@style/PlanFlowWidgetVoiceChip"
            android:layout_width="50dp"
            android:layout_height="28dp"
            android:text="입력" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_today_upcoming_event_1_title"
        style="@style/PlanFlowWidgetListText"
        android:layout_marginTop="6dp"
        tools:text="주간 회의" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_2_title"
        style="@style/PlanFlowWidgetListText"
        tools:text="점심 약속" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_3_title"
        style="@style/PlanFlowWidgetListText" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_4_title"
        style="@style/PlanFlowWidgetListText" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_5_title"
        style="@style/PlanFlowWidgetListText" />

    <TextView
        android:id="@+id/widget_today_upcoming_event_6_title"
        style="@style/PlanFlowWidgetListText" />

    <TextView
        android:id="@+id/widget_today_upcoming_empty_message"
        style="@style/PlanFlowWidgetSubtleText"
        android:visibility="gone"
        android:text="오늘 일정이 없습니다" />

</LinearLayout>
