<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_brand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PlanFlow"
            android:textColor="#1F4168"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_voice_button"
            android:layout_width="44dp"
            android:layout_height="24dp"
            android:background="@drawable/widget_voice_chip_background"
            android:gravity="center"
            android:text="입력"
            android:textColor="#1F4168"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_next_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/widget_panel_background"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/widget_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_normal_badge_background"
            android:paddingStart="8dp"
            android:paddingTop="2dp"
            android:paddingEnd="8dp"
            android:paddingBottom="2dp"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="다음 일정" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#142A44"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="주간 회의" />

        <TextView
            android:id="@+id/widget_time"
            style="@style/PlanFlowWidgetMetaText"
            android:layout_marginTop="2dp"
            tools:text="5/20 09:00" />

        <TextView
            android:id="@+id/widget_location"
            style="@style/PlanFlowWidgetMetaText"
            android:layout_marginTop="2dp"
            tools:text="강남구 테헤란로" />

        <TextView
            android:id="@+id/widget_travel_minutes"
            style="@style/PlanFlowWidgetMetaText"
            android:layout_marginTop="6dp"
            android:textColor="#1F4168"
            android:textStyle="bold"
            tools:text="이동: 25분" />

        <TextView
            android:id="@+id/widget_departure"
            style="@style/PlanFlowWidgetMetaText"
            android:layout_marginTop="2dp"
            android:textColor="#1F4168"
            android:textStyle="bold"
            tools:text="출발: 08:35" />

        <TextView
            android:id="@+id/widget_countdown"
            style="@style/PlanFlowWidgetMetaText"
            android:layout_marginTop="2dp"
            android:textColor="#D94444"
            android:textStyle="bold"
            tools:text="카운트다운: 15분" />

        <TextView
            android:id="@+id/widget_list_item_1"
            style="@style/PlanFlowWidgetMetaText"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="09:00  주간 회의" />

        <TextView
            android:id="@+id/widget_list_item_2"
            style="@style/PlanFlowWidgetMetaText"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="11:00  팀 미팅" />

        <TextView
            android:id="@+id/widget_list_item_3"
            style="@style/PlanFlowWidgetMetaText"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="13:30  점심" />
    </LinearLayout>
</LinearLayout>
