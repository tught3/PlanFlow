<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_month_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_month_today_button"
            style="@style/PlanFlowWidgetMonthNavChip"
            android:layout_width="38dp"
            android:layout_height="32dp"
            android:text="오늘" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_month_prev_button"
            style="@style/PlanFlowWidgetMonthNavButton"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="‹" />

        <TextView
            android:id="@+id/widget_month_title"
            style="@style/PlanFlowWidgetTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="80dp"
            android:gravity="center"
            tools:text="2026.05" />

        <TextView
            android:id="@+id/widget_month_next_button"
            style="@style/PlanFlowWidgetMonthNavButton"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="›" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_month_voice_button"
            style="@style/PlanFlowWidgetVoiceChip"
            android:layout_width="44dp"
            android:layout_height="28dp"
            android:text="입력" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:weightSum="7"
        tools:ignore="HardcodedText">
        <TextView style="@style/PlanFlowWidgetMonthHeader" android:text="일" />
        <TextView style="@style/PlanFlowWidgetMonthHeader" android:text="월" />
        <TextView style="@style/PlanFlowWidgetMonthHeader" android:text="화" />
        <TextView style="@style/PlanFlowWidgetMonthHeader" android:text="수" />
        <TextView style="@style/PlanFlowWidgetMonthHeader" android:text="목" />
        <TextView style="@style/PlanFlowWidgetMonthHeader" android:text="금" />
        <TextView style="@style/PlanFlowWidgetMonthHeader" android:text="토" />
    </LinearLayout>

    <!-- DIAGNOSTIC: GridLayout(42셀/300뷰) 제거, LinearLayout 6행x7칸 day-only 초경량 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="2dp"
        android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:weightSum="7">
            <TextView android:id="@+id/month_cell_1_day" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="12sp" android:textColor="#FF222222" tools:text="1" />
            <TextView android:id="@+id/month_cell_2_day" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="12sp" android:textColor="#FF222222" tools:text="2" />
