<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="planflow_home_widget_description">PlanFlow 다음 일정 위젯</string>
    <string name="planflow_next_widget_label">PlanFlow 다음 일정</string>
    <string name="planflow_next_widget_description">음성 입력으로 다음 일정을 빠르게 확인하세요</string>
    <string name="planflow_monthly_widget_label">PlanFlow 월간 일정</string>
    <string name="planflow_monthly_widget_description">이번 달 일정 개수와 중요 일정을 한눈에 확인</string>
    <string name="planflow_vertical_widget_label">PlanFlow 오늘 일정</string>
    <string name="planflow_vertical_widget_description">오늘 남은 일정을 타임라인으로 빠르게 확인</string>
    <string name="planflow_weekly_widget_label">PlanFlow 주간 일정</string>
    <string name="planflow_weekly_widget_description">일주일간 일정을 요약해서 빠르게 확인</string>
    <string name="planflow_weekly_list_widget_label">PlanFlow 주간 일정 세로형</string>
    <string name="planflow_weekly_list_widget_description">이번 주 일정을 요일별 세로 목록으로 확인</string>
    <string name="planflow_mic_widget_label">PlanFlow 음성 입력</string>
    <string name="planflow_mic_widget_description">아이콘을 탭해 음성 입력 화면을 바로 열기</string>
    <string name="planflow_group_calendar_widget_label">그룹 달력</string>
    <string name="planflow_group_calendar_widget_description">그룹 일정을 월간 달력으로 한눈에 확인</string>

    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">#EEF5FB</item>
    </style>

    <style name="PlanFlowWidgetTitleText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#183A5D</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetHintText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#1F4168</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="PlanFlowWidgetVoiceChip">
        <item name="android:background">@drawable/widget_voice_chip_background</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1F4168</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetSectionText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">#3C5D81</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetSubtleText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#9AADC0</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="PlanFlowWidgetListText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#203A57</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="PlanFlowWeeklyListDayRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:background">@drawable/widget_panel_background</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
    </style>

    <style name="PlanFlowWeeklyListDayLabel">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#183A5D</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWeeklyListEventColumn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="PlanFlowWidgetMetaText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#5F7892</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="PlanFlowWidgetMonthHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">1dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#59789A</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetMonthNavButton">
        <item name="android:background">@drawable/widget_voice_chip_background</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1F4168</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetMonthNavChip">
        <item name="android:background">@drawable/widget_voice_chip_background</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1F4168</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetWeekHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#3C5D81</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetWeekDate">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#6F8AA4</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="PlanFlowWidgetOverflowText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">start</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#8FA2B8</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="PlanFlowWidgetMonthCell">
        <item name="android:background">@drawable/widget_panel_background</item>
    </style>

    <style name="PlanFlowWidgetMonthCellDay">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1F4168</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetMonthCellMeta">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">1sp</item>
    </style>

    <style name="PlanFlowWidgetMonthCellEvent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">1dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#214E77</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="PlanFlowWidgetMonthCellOverflow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">1dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">end</item>
        <item name="android:textAlignment">viewEnd</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#214E77</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="PlanFlowWidgetMonthCellText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">#203A57</item>
        <item name="android:textSize">10sp</item>
        <item name="android:lineSpacingExtra">0dp</item>
    </style>

    <!-- 그룹 달력 위젯 프리뷰용 스타일 -->
    <style name="PlanFlowWidgetPreviewCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_gravity">fill</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">top|center_horizontal</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingLeft">1dp</item>
        <item name="android:paddingRight">1dp</item>
    </style>

    <style name="PlanFlowWidgetPreviewDay">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#203A57</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PlanFlowWidgetPreviewCount">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">#3C5D81</item>
        <item name="android:textSize">8sp</item>
        <item name="android:visibility">visible</item>
    </style>
</resources>
