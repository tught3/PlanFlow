<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="planflow_home_widget_description">PlanFlow 다음 일정 위젯</string>
    <string name="planflow_next_widget_label">PlanFlow 다음 일정</string>
    <string name="planflow_next_widget_description">음성 입력으로 다음 일정을 빠르게 확인하세요</string>
    <string name="planflow_monthly_widget_label">PlanFlow 월간 일정</string>
    <string name="planflow_monthly_widget_description">이번 달 일정 개수와 중요 일정을 한눈에 확인</string>
    <string name="planflow_vertical_widget_label">PlanFlow 오늘 일정</string>
    <string name="planflow_vertical_widget_description">오늘 남은 일정을 타임라인으로 빠르게 확인</string>
    <string name="planflow_weekly_widget_label">PlanFlow 주간 일정</string>
    <string name="planflow_weekly_widget_description">일주일간 일정을 요약해서 빠르게 확인</string>
    <string name="planflow_mic_widget_label">PlanFlow 음성 입력</string>
    <string name="planflow_mic_widget_description">아이콘을 탭해 음성 입력 화면을 바로 열기</string>

    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">#EEF5FB</item>
    </style>

    <style name="PlanFlowWidgetListText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#203A57</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="PlanFlowWidgetMetaText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#59789A</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="PlanFlowWidgetMonthCellText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">#203A57</item>
        <item name="android:textSize">10sp</item>
        <item name="android:lineSpacingExtra">0dp</item>
    </style>
</resources>
