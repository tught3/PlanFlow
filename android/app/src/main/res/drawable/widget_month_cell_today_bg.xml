<?xml version="1.0" encoding="utf-8"?>
<!-- 월간 위젯 오늘 셀 배경: 격자선 유지 + 연한 파란 배경 강조 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E7EBF1" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#DFECFD" />
        </shape>
    </item>
</layer-list>
