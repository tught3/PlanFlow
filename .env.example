# PlanFlow app runtime no longer reads .env.
# For Flutter run/build, copy env/local.example.json to env/local.json and use
# --dart-define-from-file=env/local.json.
#
# SUPABASE_URL and SUPABASE_ANON_KEY are public client config protected by RLS.
# Do not put service_role, OpenAI API keys, or OAuth client secrets in app config.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
GOOGLE_SERVER_CLIENT_ID=your-google-server-client-id.apps.googleusercontent.com
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
TMAP_API_KEY=your-tmap-api-key
NAVER_MAP_CLIENT_ID=your-naver-map-client-id
NAVER_MAP_PROXY_URL=https://your-project.supabase.co/functions/v1/naver-geocode
